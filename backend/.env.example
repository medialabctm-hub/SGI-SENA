# Configuración de la Base de Datos
DB_HOST=tu-host.proxy.rlwy.net
DB_PORT=tu_puerto
DB_USER=root
DB_PASSWORD=tu_password_de_la_bd
DB_NAME=railway

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# Configuración de JWT
JWT_SECRET=tu_super_secreto_jwt_muy_largo_y_seguro_aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=gsi-app
JWT_AUDIENCE=gsi-users

# Configuración de Email
EMAIL_USER=tu_email@dominio.com
EMAIL_PASSWORD=tu_api_key_de_brevo

# Configuración de Cookies
COOKIE_SECRET=tu_secreto_para_cookies_muy_seguro

# Configuración de CORS
CORS_ORIGIN=http://localhost:5174/

# URL del Frontend
FRONTEND_URL=http://localhost:5174/

# Configuración de Logging
LOG_LEVEL=debug

BREVO_API_KEY=tu_api_key_de_brevo
BREVO_SENDER_EMAIL=remitente_verificado@dominio.com