# ============================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL
# Conectándose a Railway Database
# ============================================
# Copia este archivo como .env y completa los valores

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (Railway)
# ============================================
# Obtén estos valores desde Railway:
# 1. Ve a tu proyecto en Railway
# 2. Ve a la pestaña "Variables"
# 3. Copia los valores de las variables MYSQL* o DB_*

DB_HOST=shuttle.proxy.rlwy.net
DB_PORT=48922
DB_USER=root
DB_PASSWORD=TkAWILndokrxg0JDbFjmObWNBjFoxXPj
DB_NAME=railway

# Alternativamente, puedes usar las variables de Railway:
# MYSQLHOST=shuttle.proxy.rlwy.net
# MYSQLPORT=48922
# MYSQLUSER=root
# MYSQLPASSWORD=TkAWILndokrxg0JDbFjmObWNBjFoxXPj
# MYSQLDATABASE=railway

# ============================================
# CONFIGURACIÓN JWT
# ============================================
JWT_SECRET=tu-super-secreto-jwt-cambiar-en-produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=gse-app
JWT_AUDIENCE=gse-users

# ============================================
# CONFIGURACIÓN DE COOKIES
# ============================================
COOKIE_SECRET=tu-secreto-cookie-cambiar-en-produccion

# ============================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO (BREVO API)
# ============================================
# Obtén tu API Key en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=tu_brevo_api_key
BREVO_SENDER_EMAIL=noreply@tudominio.com

# ============================================
# CONFIGURACIÓN CORS Y FRONTEND
# ============================================
# Para desarrollo local, usa localhost
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
LOG_LEVEL=debug

