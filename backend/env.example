# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=GestionEquipo

# ============================================
# CONFIGURACIÓN JWT
# ============================================
JWT_SECRET=tu-super-secreto-jwt-cambiar-en-produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=gse-app
JWT_AUDIENCE=gse-users

# ============================================
# CONFIGURACIÓN DE COOKIES
# ============================================
COOKIE_SECRET=tu-secreto-cookie-cambiar-en-produccion

# ============================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO (BREVO SMTP)
# ============================================
# SMTP Key de Brevo (obtener en https://app.brevo.com/settings/keys/api, pestaña SMTP)
# Debe empezar con "xsmtpsib-"
BREVO_SMTP_KEY=tu_smtp_key_de_brevo
# Login SMTP de Brevo (opcional, generalmente es [número]@smtp-brevo.com)
# Si no se especifica, se intentará usar el email del remitente
BREVO_SMTP_LOGIN=tu_login@smtp-brevo.com
# Email del remitente (debe estar verificado en Brevo)
BREVO_SENDER_EMAIL=noreply@tudominio.com
# Opcional: Mantener para compatibilidad con código antiguo
EMAIL_USER=noreply@tudominio.com
EMAIL_PASSWORD=

# ============================================
# CONFIGURACIÓN CORS Y FRONTEND
# ============================================
CORS_ORIGIN=https://sgi-sena.up.railway.app
FRONTEND_URL=https://sgi-sena.up.railway.app

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# CONFIGURACIÓN DE WEBHOOK (Opcional)
# ============================================
WEBHOOK_SECRET=

