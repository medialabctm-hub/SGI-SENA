# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=GestionEquipo

# ============================================
# CONFIGURACIÓN JWT
# ============================================
JWT_SECRET=tu-super-secreto-jwt-cambiar-en-produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=gse-app
JWT_AUDIENCE=gse-users

# ============================================
# CONFIGURACIÓN DE COOKIES
# ============================================
COOKIE_SECRET=tu-secreto-cookie-cambiar-en-produccion

# ============================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# ============================================
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_de_aplicacion

# ============================================
# CONFIGURACIÓN CORS Y FRONTEND
# ============================================
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# CONFIGURACIÓN DE WEBHOOK (Opcional)
# ============================================
WEBHOOK_SECRET=

